/* components/reminder-confirm/reminder-confirm.wxss */

.remind-card {
  margin-left: 78rpx;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-card);
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.remind-info {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.remind-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: 1.2;
}

.remind-detail {
  flex: 1;
}

.remind-time {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-1);
  display: block;
  line-height: 1.5;
}

.remind-tip {
  font-size: 22rpx;
  color: var(--text-3);
  display: block;
  margin-top: 4rpx;
}

.remind-actions {
  display: flex;
  gap: 12rpx;
}

.remind-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.remind-btn.confirm {
  background: var(--primary-10);
  color: var(--primary);
}

.remind-btn.cancel {
  background: var(--bg-input);
  color: var(--text-3);
}

.remind-btn-hover {
  opacity: 0.7;
}

/* components/alert-card/alert-card.wxss — 微信浅色风 */

.chat-msg {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #3D7EFF, #6BA3FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.bubble {
  padding: 20rpx 22rpx;
  background: var(--bg-card);
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  box-shadow: var(--shadow-card);
  flex: 1;
}

.alert-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-1);
  display: block;
  margin-bottom: 14rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  transition: transform 0.12s;
}

.alert-item:last-child { margin-bottom: 0; }
.alert-item:active { transform: scale(0.98); }

.alert-item.danger { background: rgba(250,81,81,0.06); }
.alert-item.warn { background: rgba(250,157,59,0.06); }
.alert-item.info { background: rgba(61,126,255,0.06); }

.alert-emoji {
  font-size: 28rpx;
  flex-shrink: 0;
}

.alert-text { flex: 1; }

.alert-h4 {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-1);
  display: block;
}

.alert-p {
  font-size: 20rpx;
  color: var(--text-3);
  margin-top: 2rpx;
  display: block;
}

.alert-arr {
  font-size: 24rpx;
  color: var(--text-4);
}

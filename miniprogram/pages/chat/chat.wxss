/* pages/chat/chat.wxss — 微信/元宝浅色风格 */

/* 🔒 页面根容器 */
.chat-page {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  background: var(--bg);
  overflow: hidden;
}

/* ========== 导航栏（微信风格：简洁白底） ========== */
.custom-nav {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 28rpx;
  background: var(--bg-card);
  position: relative;
  z-index: 100;
  flex-shrink: 0;
  border-bottom: 1rpx solid var(--divider);
}

.nav-left {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  border-radius: 28rpx;
  background: transparent;
  transition: background 0.15s;
}

.nav-btn-hover {
  background: var(--bg-hover);
}

.nav-btn-icon {
  font-size: 26rpx;
}

.nav-btn-text {
  font-size: 24rpx;
  color: var(--text-2);
  font-weight: 500;
}

.nav-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nav-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3D7EFF, #6BA3FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  position: relative;
}

.online-dot {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 14rpx;
  height: 14rpx;
  background: var(--success);
  border-radius: 50%;
  border: 3rpx solid var(--bg-card);
}

.online-dot.off {
  background: var(--text-4);
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: 0.5rpx;
}

.nav-right {
  width: 180rpx;
  flex-shrink: 0;
}

/* ========== 聊天内容区 ========== */
.chat-body {
  flex: 1;
  padding: 20rpx 28rpx 0;
  background: var(--bg);
  overflow-x: hidden;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  width: 100%;
}

.time-divider {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-4);
  padding: 12rpx 0 20rpx;
  letter-spacing: 1rpx;
}

/* ---- 打字动画（页面内 typing indicator） ---- */
.chat-msg {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.chat-msg.ai {
  justify-content: flex-start;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #3D7EFF, #6BA3FF);
}

.chat-bubble-wrap {
  padding: 20rpx 24rpx;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.ai-bubble {
  background: var(--bg-card);
  color: var(--text-1);
  box-shadow: var(--shadow-card);
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.25;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { opacity: 0.25; transform: translateY(0); }
  30% { opacity: 0.8; transform: translateY(-6rpx); }
}

/* ========== 底部输入区域 ========== */
.chat-input-area {
  flex-shrink: 0;
  padding: 14rpx 20rpx 0;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--divider);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 输入框 — 微信风格圆角矩形 */
.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  min-height: 72rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  padding: 0 24rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.input-wrapper-focus {
  background: var(--bg-card);
  border-color: var(--primary);
  box-shadow: 0 0 0 3rpx var(--primary-10);
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-1);
  height: 72rpx;
  line-height: 72rpx;
}

/* 发送按钮 */
.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: var(--bg-input);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn-active {
  background: var(--primary);
}

.send-btn:active {
  transform: scale(0.92);
}

.send-icon {
  font-size: 28rpx;
  color: var(--text-4);
  transition: color 0.2s;
}

.send-btn-active .send-icon {
  color: #FFFFFF;
}

/* 底部提示文字 */
.input-hint {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-4);
  padding: 10rpx 0 4rpx;
  letter-spacing: 0.5rpx;
}

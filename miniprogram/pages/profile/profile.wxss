/* pages/profile/profile.wxss — 微信浅色风 */

.profile-page {
  padding: 20rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  min-height: 100%;
  box-sizing: border-box;
  background: var(--bg);
}

/* 头部 */
.profile-header {
  text-align: center;
  padding: 16rpx 0 28rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #3D7EFF, #6BA3FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin: 0 auto 14rpx;
  box-shadow: 0 6rpx 24rpx rgba(61,126,255,0.18);
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-1);
  display: block;
}

.rank-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 18rpx;
  border-radius: 12rpx;
  background: var(--primary-10);
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 数据统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  margin: 14rpx 0;
  background: var(--bg-card);
  border-radius: 14rpx;
  box-shadow: var(--shadow-card);
}

.stat-item { text-align: center; }

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-3);
  margin-top: 4rpx;
  display: block;
}

/* 菜单列表 */
.menu-list {
  margin-top: 14rpx;
  background: var(--bg-card);
  border-radius: 14rpx;
  padding: 0 22rpx;
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.menu-item:last-child { border-bottom: none; }
.menu-item:active { opacity: 0.65; }

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.menu-text { flex: 1; }

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-1);
  display: block;
}

.menu-desc {
  font-size: 22rpx;
  color: var(--text-3);
  display: block;
}

.menu-extra {
  font-size: 24rpx;
  color: var(--text-4);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.badge {
  min-width: 28rpx;
  height: 28rpx;
  background: var(--danger);
  border-radius: 14rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-align: center;
  line-height: 28rpx;
  padding: 0 6rpx;
}

.arrow {
  font-size: 28rpx;
  color: var(--text-4);
}

.menu-item-hover {
  background: var(--bg-hover);
}

.add-tag {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: flex-end;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}

.modal-show {
  opacity: 1;
  pointer-events: auto;
}

.modal-body {
  width: 100%;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-1);
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-2);
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-input);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-1);
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: var(--bg-input);
  color: var(--text-2);
}

.modal-btn.confirm {
  background: var(--primary);
  color: #FFFFFF;
}

.modal-btn:active {
  opacity: 0.8;
}
